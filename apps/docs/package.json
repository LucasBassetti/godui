    "tailwindcss": "^4.1.6"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "shx": "^0.4.0",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
